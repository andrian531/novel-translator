    "selectors": {
        "novel_listing": [
            "article.excerpt",
            "div.hot-posts ul li",
            "div.content ul li"
        ],
        "listing_title": [
            "h2 a",
            "a"
        ],
        "listing_synopsis": [
            "p.note"
        ],
        "listing_author": [
            "span.muted",
            "a[href*='/zuozhe/']"
        ],
        "listing_href_from": "listing_title",
        "listing_chapter_count": [],
        "listing_last_update": [
            "span.muted"
        ],
        "listing_status": [],
        "novel_title": [
            "h1.article-title",
            "h1.article-title#nr_title"
        ],
        "novel_author_selectors": [
            ".article-meta",
            "h1.article-title",
            ".article-content p:contains('作者')"
        ],
        "novel_author_keyword": "作者",
        "novel_synopsis": [
            "div.article-content blockquote",
            "div.article-content p:first-child"
        ],
        "novel_status": [
            "h1.article-title"
        ],
        "chapter_list": [
            "ul.article-vlist li a",
            ".article-content a[href*='.html']"
        ],
        "chapter_content": [
            "div.article-content"
        ],
        "chapter_content_remove": [
            "script",
            "style",
            ".ads",
            ".pagination",
            ".article-social",
            ".article-tags",
            ".post-navigation"
        ]
    },
